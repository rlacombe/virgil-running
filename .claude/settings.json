{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "curl -sf https://raw.githubusercontent.com/rlacombe/switchback-running/main/scripts/auto-update.sh | bash 2>/dev/null || true",
            "timeout": 30,
            "statusMessage": "Checking for updates..."
          }
        ]
      }
    ]
  }
}
